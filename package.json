{
  "name": "community-gate",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npx concurrently -n api,web -c blue,green \"npm run dev -w @community-gate/api\" \"npm run dev -w @community-gate/web\"",
    "dev:api": "npm run dev -w @community-gate/api",
    "dev:web": "npm run dev -w @community-gate/web",
    "build": "npm run build -w @community-gate/contracts && npm run build -w @community-gate/web && npm run build -w @community-gate/api",
    "test": "npm run test -w @community-gate/api --if-present",
    "test:unit": "npm run test:unit -w @community-gate/api --if-present",
    "test:integration": "npm run test:integration -w @community-gate/api --if-present",
    "test:e2e": "npm run test:e2e -w @community-gate/web --if-present",
    "evaluate:moderation": "npm run evaluate:moderation -w @community-gate/api",
    "db:migrate": "npm run db:migrate -w @community-gate/api",
    "db:seed": "npm run db:seed -w @community-gate/api",
    "lint": "npm run lint -ws --if-present",
    "smoke": "npm run smoke -w @community-gate/api --if-present"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
